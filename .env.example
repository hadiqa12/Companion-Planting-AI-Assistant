# Copy this file to ".env" and fill in only the values you need.
# Do NOT commit the real .env file (it is ignored via .gitignore).

# --- Cloud LLM provider keys (use only ONE, depending on your provider) ---

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude): https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google AI Studio (Gemini): https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Groq: https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- LM Studio running on another machine (OpenAI-compatible) ---
# Base URL of the remote LM Studio server (no trailing slash).
LMSTUDIO_BASE_URL=
# Model identifier as it appears in LM Studio (e.g., openai/gpt-oss-20b).
LMSTUDIO_MODEL=openai/gpt-oss-20b
# Optional. Leave blank unless you enabled an API key in LM Studio.
LMSTUDIO_API_KEY=
